# The dashboard no longer calls Gemini. Its chat is proxied to the standalone
# SWE agent's local HTTP/SSE server (swe_agent/server.py, backed by Ollama).

# AGENT_SERVER_URL: where the Python SWE agent server is listening.
AGENT_SERVER_URL="http://127.0.0.1:8765"

# SWE_AGENT_SERVER_TOKEN: if the agent server was started with --token, set the
# same value here. The Node server attaches it as a bearer token on proxied
# requests so the browser never sees it. Leave unset if the agent has no token.
SWE_AGENT_SERVER_TOKEN=""
